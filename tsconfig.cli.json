{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "module": "node20",
    "moduleResolution": "node16",
    "target": "es2022",
    "outDir": "./dist",
    "rootDir": "./",
    "declaration": false,
    "sourceMap": false,
    "incremental": false,
    "jsx": "preserve",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["cli/**/*.ts", "lib/**/*.ts"],
  "exclude": ["node_modules", "app", "components", "public", ".next", "dist"]
}
